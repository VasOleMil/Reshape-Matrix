Cell["\<\
Clear[a, b, x1, x2, f1, f2, i];
FullSimplify[Solve[
   x1 = i+0; x2 = i + 1;
    a x1 + b == f1 && 
    a x2 + b == f2, {a, b}]] // InputForm
\
\>", "Text",
 CellChangeTimes->{{3.9101742398259983`*^9, 3.91017428413824*^9}, {
