    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "rn", ",", "cn", ",", "s", ",", "t", ",", "e", ",", "r", ",", "c", ",",
         "d", ",", "i", ",", "j", ",", "f"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"f", "[", 
