           RowBox[{"s", "=", "0"}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"1", "\[LessEqual]", " ", "i", "<", "2"}], 
             "                                   ", ",", 
             RowBox[{"s", "=", 
              RowBox[{"+", "1"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", " ", 
            RowBox[{
             RowBox[{
              RowBox[{"FnLen", "-", "2"}], "<", " ", "i", "\[LessEqual]", 
